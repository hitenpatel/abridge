{
	"name": "schoolconnect",
	"private": true,
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"test": "turbo test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"db:migrate": "pnpm --filter @schoolconnect/api db:migrate",
		"db:push": "pnpm --filter @schoolconnect/api db:push",
		"db:studio": "pnpm --filter @schoolconnect/api db:studio",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@playwright/test": "^1.58.1",
		"@schoolconnect/db": "workspace:*",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"turbo": "^2.3.0"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json}": ["biome check --write --no-errors-on-unmatched"]
	},
	"packageManager": "pnpm@9.15.0",
	"engines": {
		"node": ">=24.0.0"
	}
}
