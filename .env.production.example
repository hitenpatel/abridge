# ─── Abridge Production Environment Variables ────────────────────────────────
# Copy this file to .env and fill in every value before deploying.
#
#   cp .env.production.example .env
#
# NEVER commit .env to version control.
# See docs/INFRASTRUCTURE.md §7 for full reference.

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Used by the Postgres container. The API constructs its DATABASE_URL from these.
POSTGRES_USER=abridge
POSTGRES_PASSWORD=CHANGE_ME_generate_strong_password
POSTGRES_DB=abridge

# Full connection URL (auto-built by docker-compose.prod.yml from above — override here if using external DB)
# DATABASE_URL=postgresql://abridge:password@db:5432/abridge

# ── Auth (better-auth) ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=CHANGE_ME_64_char_random_string

# API base URL (used by better-auth for cookie domain and redirect URLs)
BETTER_AUTH_URL=https://api.abridge.school

# Key used to register the first school / admin account
SETUP_KEY=CHANGE_ME_your_school_setup_key

# ── URLs ──────────────────────────────────────────────────────────────────────
# Web app URL (used by Stripe for redirect URLs after payment)
WEB_URL=https://app.abridge.school

# API URL baked into the Next.js client bundle at build time
NEXT_PUBLIC_API_URL=https://api.abridge.school

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 100 emails/day
RESEND_API_KEY=re_CHANGE_ME
FROM_EMAIL=Abridge <noreply@abridge.school>

# ── Payments (Stripe) — optional ─────────────────────────────────────────────
# Leave empty to disable payment collection features
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── File Storage (Cloudflare R2) — optional ───────────────────────────────────
# Required for gallery / media uploads. Leave empty to disable uploads.
# Sign up at https://cloudflare.com → R2
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=abridge-media
R2_PUBLIC_URL=https://media.abridge.school

# ── Redis — optional ──────────────────────────────────────────────────────────
# Populated automatically from the docker-compose redis service.
# Override here if using an external Redis (e.g. Upstash).
# REDIS_URL=redis://redis:6379
# REDIS_TOKEN=

# ── Push Notifications (Expo) — optional ─────────────────────────────────────
# Required for mobile push notifications
EXPO_ACCESS_TOKEN=CHANGE_ME

# ── SMS (Twilio) — optional ───────────────────────────────────────────────────
# Required for SMS fallback notifications
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM_NUMBER=+44XXXXXXXXXX

# ── AI Progress Summaries — optional ─────────────────────────────────────────
# Set AI_SUMMARY_PROVIDER=template to disable AI calls (free, generates template text).
# Options: template | claude | openai
AI_SUMMARY_PROVIDER=template

# Claude (Anthropic) — ~£0.50/school/month
# ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# OpenAI or compatible (Groq, Gemini, etc.)
# AI_API_KEY=CHANGE_ME
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Budget cap: max tokens per school per week (default 500000)
# MAX_WEEKLY_TOKENS=500000

# Cron hours (0–23, server local time)
# SUMMARY_CRON_HOUR=6
# PAYMENT_REMINDER_HOUR=9

# ── Error Monitoring (Sentry) — optional ──────────────────────────────────────
# Sign up at https://sentry.io — free tier: 5k errors/month
SENTRY_DSN=https://CHANGE_ME@oXXXXXXXX.ingest.sentry.io/XXXXXXXX

# ── Backups (Cloudflare R2) — optional ───────────────────────────────────────
# Used by scripts/backup.sh to upload dumps offsite.
# Can reuse R2_* vars above, or a dedicated backup bucket.
BACKUP_R2_ACCOUNT_ID=${R2_ACCOUNT_ID}
BACKUP_R2_ACCESS_KEY_ID=${R2_ACCESS_KEY_ID}
BACKUP_R2_SECRET_ACCESS_KEY=${R2_SECRET_ACCESS_KEY}
BACKUP_R2_BUCKET_NAME=abridge-backups

# Local directory for backup files (used when R2 is not configured)
BACKUP_DIR=/opt/abridge/backups
