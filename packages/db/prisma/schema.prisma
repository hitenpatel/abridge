  DECLINING_TREND
  DAY_PATTERN
  POST_HOLIDAY
  BELOW_THRESHOLD
}

enum AttendanceAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model AttendanceAlert {
