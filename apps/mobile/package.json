{
  "name": "@schoolconnect/mobile",
  "private": true,
  "version": "0.0.0",
  "main": "App.tsx",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "echo 'Mobile build handled by EAS'",
    "test": "jest",
    "test:watch": "jest --watchAll"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-navigation/bottom-tabs": "^7.12.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "@tanstack/react-query": "^5.62.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "better-auth": "^1.4.18",
    "expo": "~52.0.0",
    "expo-notifications": "~0.29.11",
    "expo-secure-store": "^15.0.8",
    "expo-status-bar": "~2.0.0",
    "lucide-react-native": "^0.563.0",
    "react": "^18.3.0",
    "react-native": "0.76.0",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "^4.4.0",
    "superjson": "^2.2.0"
  },
  "devDependencies": {
    "@schoolconnect/tsconfig": "workspace:*",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@trpc/server": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.0",
    "jest": "~29.7.0",
    "jest-expo": "~52.0.6",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.{ts,tsx}",
      "**/*.test.{ts,tsx}"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(?:\\.pnpm|react-native|@react-native|react-clone-referenced-element|@react-native-community|expo(nent)?|@expo(nent)?/.*|expo-modules-core|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@tanstack/.*|@trpc/.*|superjson|lucide-react-native|better-auth|jest-expo)/)"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/react-native/build/matchers/extend-expect"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
