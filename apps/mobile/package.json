{
	"name": "@schoolconnect/mobile",
	"private": true,
	"version": "0.0.0",
	"main": "index.js",
	"scripts": {
		"dev": "expo start",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"build": "echo 'Mobile build handled by EAS'",
		"test": "jest",
		"test:watch": "jest --watchAll",
		"test:ci": "jest --ci --coverage --forceExit",
		"e2e:build:android": "detox build --configuration android.emu.debug",
		"e2e:test:android": "detox test --configuration android.emu.debug",
		"e2e:build:android:release": "detox build --configuration android.emu.release",
		"e2e:test:android:release": "detox test --configuration android.emu.release"
	},
	"dependencies": {
		"@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
		"@expo/vector-icons": "^15.0.3",
		"@react-navigation/bottom-tabs": "^7.12.0",
		"@react-navigation/native": "^7.1.28",
		"@react-navigation/native-stack": "^7.12.0",
		"@tanstack/react-query": "^5.62.0",
		"@trpc/client": "^11.0.0",
		"@trpc/react-query": "^11.0.0",
		"better-auth": "^1.4.18",
		"class-variance-authority": "^0.7.1",
		"expo": "~54.0.33",
		"expo-clipboard": "^8.0.8",
		"expo-file-system": "^19.0.21",
		"expo-font": "^14.0.11",
		"expo-haptics": "^15.0.8",
		"expo-image-picker": "^17.0.10",
		"expo-notifications": "~0.32.16",
		"expo-secure-store": "^15.0.8",
		"expo-status-bar": "~3.0.9",
		"lucide-react-native": "^0.563.0",
		"nativewind": "^4",
		"react": "19.1.0",
		"react-native": "0.81.5",
		"react-native-css-interop": "0.2.1",
		"react-native-reanimated": "^3.19.5",
		"react-native-safe-area-context": "~5.6.0",
		"react-native-screens": "~4.16.0",
		"react-native-svg": "15.12.1",
		"react-native-worklets": "^0.7.4",
		"superjson": "^2.2.0",
		"tailwindcss": "^3.4.0"
	},
	"devDependencies": {
		"@config-plugins/detox": "^11.0.0",
		"@schoolconnect/tsconfig": "workspace:*",
		"@schoolconnect/ui-config": "workspace:^",
		"@testing-library/jest-native": "^5.4.3",
		"@testing-library/react-native": "^13.3.3",
		"@trpc/server": "^11.0.0",
		"@types/jest": "29.5.14",
		"@types/react": "^19.1.0",
		"detox": "^20.47.0",
		"jest": "~29.7.0",
		"jest-expo": "~54.0.17",
		"react-dom": "19.1.0",
		"react-test-renderer": "19.1.0",
		"typescript": "^5.7.0"
	},
	"jest": {
		"preset": "jest-expo",
		"testMatch": ["**/__tests__/**/*.test.{ts,tsx}", "**/*.test.{ts,tsx}"],
		"modulePathIgnorePatterns": ["<rootDir>/e2e/"],
		"transformIgnorePatterns": [
			"node_modules/(?!(?:\\.pnpm|react-native|@react-native|react-clone-referenced-element|@react-native-community|expo(nent)?|@expo(nent)?/.*|expo-modules-core|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@tanstack/.*|@trpc/.*|superjson|lucide-react-native|better-auth|jest-expo|nativewind|react-native-css-interop|class-variance-authority|expo-secure-store|expo-font|expo-haptics|expo-clipboard)/)"
		],
		"setupFiles": ["./src/__tests__/__mocks__/expo-modules.ts"],
		"setupFilesAfterEnv": ["@testing-library/react-native/build/matchers/extend-expect"],
		"moduleNameMapper": {
			"^react$": "<rootDir>/node_modules/react",
			"^react/(.*)$": "<rootDir>/node_modules/react/$1",
			"^@/(.*)$": "<rootDir>/src/$1"
		}
	}
}
