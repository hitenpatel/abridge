{
	"name": "@schoolconnect/api",
	"private": true,
	"version": "0.0.0",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"test": "vitest",
		"db:migrate": "prisma migrate dev --schema=../../packages/db/prisma/schema.prisma",
		"db:push": "prisma db push --schema=../../packages/db/prisma/schema.prisma",
		"db:studio": "prisma studio --schema=../../packages/db/prisma/schema.prisma"
	},
	"dependencies": {
		"@elastic/elasticsearch": "^9.2.1",
		"@fastify/cors": "^10.0.0",
		"@schoolconnect/db": "workspace:*",
		"@trpc/server": "^11.0.0",
		"better-auth": "^1.4.18",
		"date-fns": "^4.1.0",
		"expo-server-sdk": "^3.15.0",
		"fastify": "^5.2.0",
		"fastify-raw-body": "^5.0.0",
		"stripe": "^20.3.0",
		"superjson": "^2.2.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@schoolconnect/tsconfig": "workspace:*",
		"@types/node": "^22.0.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	}
}
