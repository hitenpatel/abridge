{
	"name": "@schoolconnect/api",
	"private": true,
	"version": "0.0.0",
	"scripts": {
		"dev": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"test": "vitest",
		"db:migrate": "prisma migrate dev --schema=../../packages/db/prisma/schema.prisma",
		"db:push": "prisma db push --schema=../../packages/db/prisma/schema.prisma",
		"db:studio": "prisma studio --schema=../../packages/db/prisma/schema.prisma"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.990.0",
		"@aws-sdk/s3-request-presigner": "^3.990.0",
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^10.0.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/rate-limit": "^10.3.0",
		"@react-pdf/renderer": "^4.3.2",
		"@schoolconnect/db": "workspace:*",
		"@sentry/node": "^10.39.0",
		"@sentry/profiling-node": "^10.39.0",
		"@trpc/server": "^11.0.0",
		"@types/pdfkit": "^0.17.4",
		"better-auth": "^1.4.18",
		"date-fns": "^4.1.0",
		"expo-server-sdk": "^3.15.0",
		"fastify": "^5.2.0",
		"fastify-raw-body": "^5.0.0",
		"google-translate-api-x": "^10.7.2",
		"ioredis": "^5.9.2",
		"pdf-parse": "^2.4.5",
		"pdfkit": "^0.17.2",
		"pino": "^10.3.1",
		"resend": "^6.9.1",
		"sharp": "^0.34.5",
		"stripe": "^20.3.0",
		"superjson": "^2.2.0",
		"tesseract.js": "^7.0.0",
		"tsx": "^4.19.0",
		"twilio": "^5.12.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@schoolconnect/tsconfig": "workspace:*",
		"@types/node": "^22.0.0",
		"@types/pdf-parse": "^1.1.5",
		"@types/react": "^19.1.0",
		"@types/sharp": "^0.32.0",
		"pino-pretty": "^13.1.3",
		"prisma": "^6.3.0",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	}
}
