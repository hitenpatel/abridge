{
  "extends": "@schoolconnect/tsconfig/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@schoolconnect/api/*": [
        "../../apps/api/src/*"
      ]
    },
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "declaration": false
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../../apps/api/src/router/index.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
