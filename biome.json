{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"overrides": [
		{
			"include": [
				"**/*.test.ts",
				"**/*.test.tsx",
				"**/__tests__/**/*",
				"apps/api/src/router/payments.ts",
				"apps/api/src/lib/stripe.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	],
	"files": {
		"ignore": ["node_modules", ".next", "dist", ".expo", "*.generated.*"]
	}
}
