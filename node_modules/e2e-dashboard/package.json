{
  "name": "e2e-dashboard",
  "version": "0.1.0",
  "description": "Standalone E2E test dashboard with screenshots for GitHub/Forgejo Pages",
  "type": "module",
  "bin": {
    "e2e-dashboard": "./bin/cli.js"
  },
  "exports": {
    ".": "./parser/index.js",
    "./dashboard": "./dashboard/index.html"
  },
  "files": [
    "bin/",
    "parser/",
    "merger/",
    "scaffold/",
    "dashboard/",
    "templates/"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.3.0"
  },
  "license": "MIT"
}
